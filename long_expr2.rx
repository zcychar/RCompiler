    out2 = norm(out2 * 16 + f05 * 7 + 282, 1000003);
    out2 = norm(out2 * 17 + f06 * 8 + 335, 1000003);
    out2 = norm(out2 * 11 + f07 * 9 + 388, 1000003);
    out2 = norm(out2 * 12 + f08 * 10 + 441, 1000003);
    out2 = norm(out2 * 13 + f09 * 11 + 494, 1000003);
    out2 = norm(out2 * 14 + f10 * 12 + 547, 1000003);
    out2 = norm(out2 * 15 + f11 * 13 + 600, 1000003);
    out2 = norm(out2 * 16 + f12 * 14 + 653, 1000003);
    out2 = norm(out2 * 17 + f13 * 15 + 706, 1000003);
    out2 = norm(out2 * 11 + f14 * 16 + 759, 1000003);
    out2 = norm(out2 * 12 + f15 * 17 + 812, 1000003);
    out2 = norm(out2 * 13 + f16 * 18 + 865, 1000003);
    out2 = norm(out2 * 14 + f17 * 19 + 918, 1000003);
    printlnInt(out0);
    printlnInt(out1);
    printlnInt(norm(out0 * 31 + out1 * 37 + out2 * 41 + branch_sum * 43, 1000003));
    exit(0);
}
